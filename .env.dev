# Local development / integration-test database.
# Non-secret defaults; safe to commit. Override locally as needed.
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_PORT=5432

# Consumed by integration tests (go test -tags=integration) and examples/showcase.
DATABASE_URL=postgres://app:app@localhost:5432/app?sslmode=disable
DEMO_DATABASE_URL=postgres://app:app@localhost:5432/demo?sslmode=disable
